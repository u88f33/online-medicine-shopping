<%- include( "../partials/adminprofilesidebar" ) -%>

<div class="admin-container">

    <div class="row p-5 pb-3">
        <div class="col-7 d-flex">
            <h1 class="m-0">Suppliers Data</h1>
        </div>

        <div class="col-5 d-flex">
            <a href="/admin/addsupplier" class="btn btn-danger ms-auto fs-5">
                Add New Supplier
            </a>
        </div>
    </div>

    <div class="row p-5 pb-3">
        <div class="col-12">
            
            <%# Showing Customer Records in a Table %>
            <table class="table fs-7">
            <thead>
                <tr style="border-bottom: 2px solid black;">
                    <th scope="col">#</th>
                    <th scope="col">Name</th>
                    <th scope="col">Phone number</th>
                    <th scope="col">Address</th>
                    <th scope="col" style="width:40%;">Actions</th>
                </tr>
            </thead>
            <tbody>

                <% let number = 0; %>
                <% suppliersData.forEach(supplier => { %>
                    <tr style="border-bottom: 1px solid grey;" class="align-middle" >
                    <td><%= ++number %></td>
                    <td><%= supplier.name %></td>
                    <td><%= supplier.contact_number %></td>
                    <td><%= supplier.address %></td>
                    <td>
                        <%# See Customer details and Login %>
                        <a href="#" class="btn btn-primary">View Full Details</a>
                        
                        <a href="#" class="btn btn-danger">Edit</a>
                        <a href="#" class="btn btn-warning">Delete</a>
                    </td>
                </tr>
                <% }); %>
                
            </tbody>
            </table>

        </div>
    </div>


</div>

<%- include( "../partials/footer" ) -%>