<%- include( "../partials/adminprofilesidebar" ) -%>

<div class="admin-container">

    <div class="row p-5 pb-3">
        <div class="col-12 d-flex justify-content-center">

        <form 
            action="/admin/addsupplier"
            method="POST"
            class="bg-dark text-light rounded rounded-4 p-4 w-100">

            <div class="text-light pt-5 pb-5">
                <h1 class="fs-2">Add New Supplier Record</h1>
            </div>

                <div class="d-flex">
                    <div class="mb-3 me-4 w-50">
                        <label for="exampleInputName" class="form-label">Supplier Name:</label>
                        <input type="text" 
                            class="form-control" 
                            id="exampleInputName" 
                            aria-describedby="nameHelp"
                            placeholder="Enter name of Supplier"
                            min="2"
                            max="50"
                            name="supplier_name">
                    </div>

                    <div class="mb-3 me-4 w-50">
                        <label for="exampleInputPhone" class="form-label">Supplier Phone number</label>
                        <input type="text" 
                            class="form-control"
                            placeholder="Enter Supplier's Phone number"
                            id="exampleInputPhone" 
                            aria-describedby="phoneHelp"
                            name="supplier_phone">
                    </div>

                </div>



                <div class="mb-4">
                    <label for="exampleInputAddress" class="form-label">Supplier Address</label>
                    <input type="text" 
                        class="form-control"
                        placeholder="Enter Address of the Supplier"
                        id="exampleInputAddress"
                        name="supplier_address">
                </div>

            <div class="d-flex mt-5">
                <a href="/admin/customers" class="btn btn-warning ms-auto me-2">Go Back</a>
                <button type="submit" class="btn btn-danger bg-danger">Submit</button>
            </div>
        </form>

        </div>
    </div>


</div>

<%- include( "../partials/footer" ) -%>