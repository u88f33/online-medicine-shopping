<%- include( "../partials/header" ) -%>

<div class="container mt-5">

    <div class="row">
        <div class="col-12 d-flex justify-content-center">

            <div class="rounded rounded-4 bg-dark p-5 mt-5 mb-5 w-50 text-light">

                <div class="w-100 text-left pb-5">
                    <h1>Reset Password</h1>
                </div>

                <form action="/forgotpassword" method="POST">
                    <div class="mb-4">
                        <label for="exampleInputEmail1" 
                        class="form-label">
                        Enter your Email
                        </label>
                        
                        <input 
                            type="email" 
                            class="form-control" 
                            id="exampleInputEmail1" 
                            aria-describedby="emailHelp"
                            name="customer_email">
                    </div>
                    
                    <div class="d-flex justify-content-right">
                        <button type="submit" class="btn border-light text-light px-3 ms-auto btn-hover">
                            Send Reset Link
                        </button>
                    </div>

                </form>

                <%#-- If Email or Password does not matched, show message in box --%>
                <% if ( errorMessage ) { %>
                    <div class="alert alert-danger d-flex align-items-center mt-4" role="alert">
                        <div>
                            <strong>Error:</strong> <%= errorMessage %>
                        </div>
                    </div>
                <% } %>

            </div>

        </div>
    </div>

</div>

<%- include( "../partials/footer" ) -%>