<%- include( "../partials/userprofileheader" ) -%>

<div class="container">
    <div class="row p-5 pb-3">
        <div class="col-12 d-flex justify-content-center">

        <form 
            action="/profile/updateprofile"
            method="POST"
            class="bg-dark text-light rounded rounded-4 p-4 w-100">

            <div class="text-light pt-5 pb-5">
                <h1 class="fs-2">Update Your Profile</h1>
            </div>

            <div class="d-flex">
                <div class="mb-3 me-4 w-50">
                    <label for="exampleInputName" class="form-label">Name</label>
                    <input type="text" 
                        class="form-control" 
                        id="exampleInputName" 
                        aria-describedby="nameHelp"
                        placeholder="Write your name"
                        min="2"
                        max="50"
                        name="customer_name"
                        value="<%= getRecordValuesinUpdateForm.name %>"
                        required="true">
                </div>

                <div class="mb-3 w-50">
                    <label for="exampleInputEmail" class="form-label">Email</label>
                    <input type="email" 
                        class="form-control" 
                        placeholder="Write your Email"
                        id="exampleInputEmail" 
                        aria-describedby="emailHelp"
                        name="customer_email"
                        value="<%= getRecordValuesinUpdateForm.email %>"
                        required="true">
                </div>
            </div>


            <div class="d-flex">
                <div class="mb-3 me-4 w-50">
                    <label for="exampleInputPhone" class="form-label">Phone</label>
                    <input type="text" 
                        class="form-control"
                        placeholder="Enter your Phone number"
                        id="exampleInputPhone" 
                        aria-describedby="phoneHelp"
                        name="customer_phone"
                        value="<%= getRecordValuesinUpdateForm.phone %>"
                        required="true">
                </div>

                <div class="mb-3 w-50">
                    <label for="exampleInputPassword" class="form-label">
                        Change Password (or Enter old Password)
                    </label>
                    <input type="password"
                        class="form-control" 
                        id="exampleInputPassword"
                        placeholder="Type Password"
                        aria-describedby="passwordHelp"
                        name="customer_password"
                        required="true">
                </div>
            </div>

            <div class="mb-3">
                <label for="exampleInputAddress" class="form-label">Address</label>
                <input type="text" 
                    class="form-control"
                    placeholder="Enter your Address"
                    id="exampleInputAddress"
                    name="customer_address"
                    value="<%= getRecordValuesinUpdateForm.address %>"
                    required="true">
            </div>

            <div class="d-flex mt-5">
                <a href="/profile" class="btn btn-warning ms-auto me-2">Go Back</a>
                <button type="submit" class="btn btn-danger bg-danger">Update Profile</button>
            </div>
        </form>

        </div>
    </div>
</div>


<%- include( "../partials/footer" ) -%>
